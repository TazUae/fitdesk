# ─────────────────────────────────────────────────────────────────────────────
# FitDesk — Environment Variables
#
# Copy this file to .env and fill in every value before running the app.
# NEVER commit .env to version control.
#
# Generate a random secret: openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────────────────

# Public URL of this deployment — used in auth redirects and email links.
# Local:      http://localhost:3000
# Production: https://fitdesk.yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Client-side API base for same-origin requests. Keep relative in all envs.
NEXT_PUBLIC_API_URL=/api

# Optional: shown in the /api/health response for deployment identification.
APP_VERSION=1.0.0

# ─── Better Auth ──────────────────────────────────────────────────────────────

# Strong random secret — must be at least 32 characters.
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Must match NEXT_PUBLIC_APP_URL exactly (no trailing slash).
BETTER_AUTH_URL=http://localhost:3000
# Internal app URL used by server-side middleware/auth checks.
# In Dokploy/containers, keep this on local HTTP to avoid TLS loopback issues.
INTERNAL_API_URL=http://127.0.0.1:3000

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
# Leave blank to disable Google sign-in. Both values required to enable it.
# Console: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Auth Database (SQLite via LibSQL) ───────────────────────────────────────
# Local development:
#   DATABASE_URL=file:./auth.db
#
# Docker deployment (uses the db_data volume at /app/data):
#   DATABASE_URL=file:/app/data/auth.db
#
# Production with Turso (recommended for multi-instance):
#   DATABASE_URL=libsql://your-db-name.turso.io
#   DATABASE_AUTH_TOKEN=<your-turso-token>
DATABASE_URL=file:./auth.db
DATABASE_AUTH_TOKEN=

# ─── Control Plane ERP Proxy ─────────────────────────────────────────────────
# FitDesk no longer calls ERPNext directly. All business data flows through
# the Control Plane's DocType proxy (GET/POST/PUT /api/erp/doctype/*).
#
# CONTROL_PLANE_URL: URL of the running control-plane service.
# Local dev: http://localhost:4000   Production: internal Docker network URL.
CONTROL_PLANE_URL=http://localhost:4000

# CONTROL_PLANE_API_KEY: used for tenant provisioning endpoints (/tenants, /jobs).
CONTROL_PLANE_API_KEY=dev-only-control-plane-api-key-min-16

# FITDESK_JWT_SECRET: shared HMAC-HS256 secret for ERP proxy JWT signing.
# Must be at least 32 characters and match FITDESK_JWT_SECRET in the Control Plane.
# Generate: openssl rand -hex 32
FITDESK_JWT_SECRET=dev-only-fitdesk-jwt-secret-min-32-characters

# ─── Evolution API (WhatsApp) ─────────────────────────────────────────────────
# Base URL of your Evolution API instance — no trailing slash.
EVOLUTION_API_URL=https://your-evolution.example.com

# API key set in your Evolution API config.
EVOLUTION_API_KEY=

# The Evolution instance name (WhatsApp connection identifier).
# Must match the instance created in the Evolution API dashboard.
EVOLUTION_INSTANCE_NAME=fitdesk

# ─── Whish Payments ──────────────────────────────────────────────────────────
# Leave blank to disable Whish. Cash and bank transfer always remain available.
# Contact Whish Money for merchant API credentials.
WHISH_API_URL=
WHISH_API_KEY=
WHISH_MERCHANT_ID=

# ─── AI Message Generation (Claude) ──────────────────────────────────────────
# Optional. When set, the message composer uses Claude to generate drafts.
# Without this key, high-quality professional templates are used instead.
# Get a key at: https://console.anthropic.com
ANTHROPIC_API_KEY=
